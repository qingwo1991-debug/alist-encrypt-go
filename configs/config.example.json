{
  "scheme": {
    "address": "0.0.0.0",
    "http_port": 5344,
    "https_port": -1,
    "force_https": false,
    "cert_file": "",
    "key_file": "",
    "unix_file": "",
    "unix_file_perm": "",
    "enable_h2c": false
  },
  "alist": {
    "host": "localhost",
    "port": 5244,
    "https": false
  },
  "alistServer": {
    "followRedirectForDecrypt": true,
    "redirectMaxHops": 2,
    "allowLooseDecode": false,
    "requestTimeoutSeconds": 20,
    "enableStartupProbe": false,
    "startupProbeDelaySeconds": 5,
    "startupProbeIntervalMinutes": 0,
    "negativeCacheMinutes": 120,
    "streamStrategyOverrides": [
      {
        "pathPrefix": "/移动云盘156/encrypt",
        "strategy": "full"
      }
    ],
    "enableBackgroundProbe": true,
    "probeConcurrency": 4,
    "probeProviderConcurrency": 1,
    "probeMinDelayMs": 3000,
    "probeMaxDelayMs": 15000,
    "probeCooldownMinutes": 1440,
    "probeQueueSize": 1000,
    "probeMinSizeBytes": 104857600
  },
  "cache": {
    "enable": true,
    "expiration": 10,
    "cleanup_interval": 5
  },
  "proxy": {
    "max_idle_conns": 100,
    "max_idle_conns_per_host": 100,
    "max_conns_per_host": 100,
    "idle_conn_timeout": 90,
    "enable_http2": true,
    "insecure_skip_verify": false,
    "mode": "rules",
    "url": "http://host.docker.internal:7890",
    "no_proxy": [
      "localhost",
      "127.0.0.1",
      "openalist",
      "mysql",
      "192.168.1.0/24"
    ],
    "selected_provider_ids": [
      "google_drive",
      "google_photo",
      "onedrive",
      "dropbox"
    ],
    "selected_domains": [
      "googleapis.com",
      "googleusercontent.com",
      "graph.microsoft.com",
      "dropboxapi.com"
    ],
    "rules": [
      {
        "id": "google-apis",
        "provider_id": "google_drive",
        "match_type": "domain_suffix",
        "pattern": "googleapis.com",
        "action": "proxy",
        "enabled": true,
        "priority": 100
      }
    ],
    "dial_timeout_seconds": 30,
    "tls_handshake_timeout_seconds": 10,
    "response_header_timeout_seconds": 15
  },
  "log": {
    "level": "info",
    "format": "console",
    "output": "stdout"
  },
  "data_dir": "./data",
  "database": {
    "type": "mysql",
    "dsn": "<db_user>:<db_password>@tcp(<db_host>:3306)/<db_name>?charset=utf8mb4&parseTime=True&loc=Local",
    "max_open_conns": 10,
    "max_idle_conns": 5,
    "conn_max_lifetime_seconds": 300,
    "conn_max_idle_seconds": 60,
    "flush_interval_seconds": 5,
    "cleanup_days": 30,
    "cleanup_interval_hours": 24
  },
  "jwt_secret": "change-this-to-a-secure-random-string",
  "jwt_expire": 24
}
